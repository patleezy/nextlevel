# Gemini API key — required for AI Take (compare panel) and game discovery script
# Get one free at https://aistudio.google.com/
GEMINI_API_KEY=your_google_gemini_api_key_here

# Tavily API key — optional, improves game discovery with web search
# Get one at https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# RAWG API key — for game thumbnails. Get a free key at https://rawg.io/apidocs
# Prefix VITE_ is required for Vite to expose it to the browser bundle.
# Falls back to a shared public key if not set.
VITE_RAWG_API_KEY=your_rawg_api_key_here
